# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grocery_booking
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_LOGGING=false

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bootstrap Admin (created on first run via seed)
ADMIN_EMAIL=admin@grocery.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Default Admin

{
  "info": {
    "name": "Grocery Booking System",
    "description": "Postman collection for QuestionPro Senior Software Engineer (Node.js) assessment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "groceryId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Auth — Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.token) {",
              "  pm.collectionVariables.set('adminToken', json.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@grocery.local\",\n  \"password\": \"Admin@12345\"\n}"
        }
      }
    },
    {
      "name": "Auth — Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.token) {",
              "  pm.collectionVariables.set('userToken', json.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Pass1234\"\n}"
        }
      }
    },
    {
      "name": "Auth — Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.token) {",
              "  pm.collectionVariables.set('userToken', json.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Pass1234\"\n}"
        }
      }
    },
    {
      "name": "Auth — Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Admin — Create Grocery",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.collectionVariables.set('groceryId', json.data.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/groceries",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mango (Alphonso)\",\n  \"description\": \"Premium Alphonso mangoes\",\n  \"category\": \"Fruits\",\n  \"unit\": \"kg\",\n  \"price\": 6.49,\n  \"stock\": 100\n}"
        }
      }
    },
    {
      "name": "Admin — List Groceries (all)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/groceries/admin/all?page=1&limit=20"
      }
    },
    {
      "name": "Admin — Update Grocery",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/groceries/{{groceryId}}",
        "body": { "mode": "raw", "raw": "{\n  \"price\": 7.25\n}" }
      }
    },
    {
      "name": "Admin — Manage Inventory (increment)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/groceries/{{groceryId}}/inventory",
        "body": { "mode": "raw", "raw": "{\n  \"operation\": \"increment\",\n  \"quantity\": 25\n}" }
      }
    },
    {
      "name": "Admin — Delete Grocery",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/groceries/{{groceryId}}"
      }
    },
    {
      "name": "User — List Available Groceries",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/groceries?inStock=true&sortBy=price&sortOrder=asc"
      }
    },
    {
      "name": "User — Place Multi-Item Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.data && json.data.id) {",
              "  pm.collectionVariables.set('orderId', json.data.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{userToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    { \"groceryId\": \"{{groceryId}}\", \"quantity\": 2 }\n  ]\n}"
        }
      }
    },
    {
      "name": "User — My Orders",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/orders"
      }
    },
    {
      "name": "User — My Order by ID",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": "{{baseUrl}}/orders/{{orderId}}"
      }
    },
    {
      "name": "Admin — All Orders",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/orders/admin/all"
      }
    }
  ]
}
